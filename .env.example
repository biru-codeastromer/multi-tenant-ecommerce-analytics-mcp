# ---------------------------------------------------------------------------
# Copy to `.env` and fill in. `.env` is gitignored — never commit real values.
# ---------------------------------------------------------------------------

# --- Database ---------------------------------------------------------------
# OWNER connection. Used ONLY by migrations, the seed script and the discovery
# job. The MCP server process never opens a connection with this URL.
# On Supabase this is the `postgres` user via the SESSION pooler (port 5432)
# or the direct connection — migrations need session-level DDL.
DATABASE_URL_OWNER=postgresql://zyaro_owner:local_dev_only_password@localhost:54329/zyaro_events

# TENANT connection. The role that serves every analytics query.
# SELECT-only, owns nothing, RLS applies to it (and is FORCED anyway).
# On Supabase use the TRANSACTION pooler (port 6543) for this one.
DATABASE_URL_TENANT=postgresql://mcp_tenant:CHANGE_ME_TENANT_PASSWORD@localhost:54329/zyaro_events

# AUTH connection. Resolves an API key to an org. Can read `api_credentials`
# and nothing else. Kept separate so the tenant role never touches the
# credential table, even accidentally.
DATABASE_URL_AUTH=postgresql://mcp_auth:CHANGE_ME_AUTH_PASSWORD@localhost:54329/zyaro_events

# Passwords the migration runner assigns to the two application roles.
# Must match the passwords embedded in the URLs above.
MCP_TENANT_PASSWORD=CHANGE_ME_TENANT_PASSWORD
MCP_AUTH_PASSWORD=CHANGE_ME_AUTH_PASSWORD

# Server-side pepper mixed into the API-key hash. Rotating this invalidates
# every issued credential. Generate with: openssl rand -hex 32
API_KEY_PEPPER=CHANGE_ME_GENERATE_A_64_CHAR_HEX_STRING

# --- Server -----------------------------------------------------------------
PORT=8787
NODE_ENV=development
LOG_LEVEL=info

# --- Query safety knobs -----------------------------------------------------
# Also enforced at the database-role level via ALTER ROLE; these are the
# belt to the database's braces.
STATEMENT_TIMEOUT_MS=8000
MAX_ROWS_RETURNED=500
RATE_LIMIT_PER_MINUTE=60

# --- Demo -------------------------------------------------------------------
# When true, `npm run db:seed` prints the generated demo API keys to stdout.
# They are shown exactly once; only the hash is persisted.
PRINT_DEMO_CREDENTIALS=true
